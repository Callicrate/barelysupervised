{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${PLUGIN_ROOT}/hooks/install_agents.py\"",
            "command_windows": "python \"%PLUGIN_ROOT%\\hooks\\install_agents.py\"",
            "statusMessage": "Loading BarelySupervised roster"
          }
        ]
      }
    ]
  }
}
