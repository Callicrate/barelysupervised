{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${PLUGIN_ROOT}/hooks/bootstrap.py\"",
            "commandWindows": "py -3 \"%PLUGIN_ROOT%/hooks/bootstrap.py\"",
            "statusMessage": "Bootstrapping BarelySupervised global profiles and skill"
          }
        ]
      }
    ]
  }
}
